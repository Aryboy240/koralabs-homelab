# DOMAIN_NAME and SUBDOMAIN together determine where n8n will be reachable from
# The top level domain to serve from
DOMAIN_NAME= # Set your own domain name here, e.g. example.com

# The subdomain to serve from
SUBDOMAIN= # Set your own subdomain name here (the bit that comes before the domain name), e.g. n8n

# Tell n8n the external URL
N8N_HOST= # set this to the $SUBDOMAIN.$DOMAIN_NAME
N8N_PROTOCOL=https
WEBHOOK_URL=https://#$SUBDOMAIN.$DOMAIN_NAME

# Optional timezone to set which gets used by Cron and other scheduling nodes
# New York is the default value if not set
GENERIC_TIMEZONE=Europe/London